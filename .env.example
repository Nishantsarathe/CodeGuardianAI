# ==============================================
# CodeGuardian AI - Environment Configuration
# ==============================================
# Copy this file to `.env` and fill in the values.
# Never commit your real `.env` file.
#
# Generate secrets with:
#   python -c "import secrets; print(secrets.token_hex(32))"

# -------------------- General --------------------
APP_NAME=CodeGuardian-AI
APP_ENV=development          # development | staging | production
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000

# -------------------- Security --------------------
# REQUIRED — generate unique values, never use these placeholders in production.
# openssl rand -hex 32
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MIN=60
JWT_REFRESH_TTL_DAYS=7
RATE_LIMIT_PER_MIN=60

# -------------------- Demo user --------------------
# Password for the auto-seeded admin account (dev/test only).
# If unset a random password is generated and printed to the server log.
# This setting has no effect when APP_ENV=production.
DEMO_ADMIN_PASSWORD=

# -------------------- Database --------------------
DATABASE_URL=sqlite:///./codeguardian.db

# -------------------- Vector DB --------------------
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION=codeguardian

# -------------------- LLM / Ollama --------------------
# If the backend runs in Docker/docker-compose while Ollama runs on your
# HOST machine (not in a container), "localhost" here refers to the
# container itself and Ollama will be unreachable — connections may hang
# instead of failing instantly, which can make analyses appear to take a
# very long time. In that setup, use instead:
#   OLLAMA_BASE_URL=http://host.docker.internal:11434
# (On Linux, also add `extra_hosts: ["host.docker.internal:host-gateway"]`
# to the backend service in docker-compose.yml.)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=gemma2:2b
OLLAMA_FALLBACK_MODEL=qwen2.5-coder:7b
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048
LLM_TIMEOUT_SEC=120

# -------------------- Agents --------------------
AGENT_MAX_RETRIES=2
AGENT_PARALLEL_LIMIT=4
AGENT_VERBOSE=true

# -------------------- Uploads --------------------
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=100
ALLOWED_EXTS=.py,.java,.js,.ts,.tsx,.jsx,.go,.rs,.c,.cc,.cpp,.h,.hpp,.cs,.zip,.tar,.gz

# -------------------- MCP --------------------
ENABLE_MCP_FILESYSTEM=true
ENABLE_MCP_GITHUB=true
ENABLE_MCP_SQLITE=true
# Optional — needed for private repos or to avoid GitHub API rate limits
GITHUB_TOKEN=

# -------------------- Logging --------------------
LOG_LEVEL=INFO
LOG_FILE=./logs/codeguardian.log
